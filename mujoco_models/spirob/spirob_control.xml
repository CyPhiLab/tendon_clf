<mujoco model="scene">

    <include file="spirob.xml" />
    <visual>

        <!-- completely disable haze / fog -->
        <rgba haze="0 0 0 0"/>

        <!-- disable default shadow softness -->
        <map shadowclip="0"/>

        <!-- remove sky gradient blending -->
        <quality shadowsize="0"/>

    </visual>


    <!-- ================= VISUAL ================= -->
    <visual>

        <!-- softer but visible lighting on dark bg -->
        <headlight diffuse="0.9 0.9 0.9"
                   ambient="0.15 0.15 0.15"
                   specular="0 0 0"/>

        <!-- dark atmosphere -->
        <rgba haze="0 0 0 0"/>

        <global azimuth="160" elevation="0"
                offwidth="1920" offheight="1080"/>

    </visual>


    <!-- ================= BACKGROUND ================= -->
    <asset>

        <!-- solid dark background -->
        <texture type="skybox"
                builtin="gradient"
                rgb1="0 0 0"
                rgb2="0 0 0"
                width="512"
                height="512"/>


        <!-- subtle dark grid floor -->
        <texture type="2d" name="groundplane"
                 builtin="checker"
                 rgb1="0.08 0.08 0.09"
                 rgb2="0.04 0.04 0.045"
                 width="300" height="300"/>

        <material name="groundplane"
                  texture="groundplane"
                  texuniform="true"
                  texrepeat="6 6"
                  reflectance="0"/>

    </asset>


    <!-- ================= WORLD ================= -->
    <worldbody>

        <light pos="0 0 3.5" dir="0 0 -1" directional="true"/>

        <!-- <geom name="floor"
              type="plane"
              size="0 0 0.05"
              pos="0 0 0"
              material="groundplane"/> -->

        <!-- target -->
        <body name="target" mocap="true" pos="0.2 0.0 0.2">
            <geom name="target_vis"
                  type="sphere"
                  size="0.02"
                  rgba="1 0.2 0.2 0.9"
                  contype="0"
                  conaffinity="0"/>
        </body>

        <camera name="ortho_side"
            mode="fixed"
            orthographic="true"
            pos="0.1 -1 0.3"
            xyaxes="1 0 0  0 0 1"
            fovy="1.0"/>

    </worldbody>



</mujoco>
