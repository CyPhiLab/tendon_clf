<mujoco model="4link_tendon_planar">
    <compiler angle="radian"/>
    <option gravity="0 0 -9.81" integrator="implicitfast" timestep="0.005"/>

    <default>
        <joint type="hinge" axis="0 1 0" limited="true" range="-1.57 1.57" damping="0.01"/>
        <geom type="capsule" size="0.005 0.03" rgba="1 1 1 1" mass="0.01"/>

    </default>

    <!-- <asset>
        <texture type="skybox" builtin="flat" rgb1="1 1 1" rgb2="0 0 0" width="512" height="3072"/>
    </asset> -->

        <!-- ================= BACKGROUND ================= -->
    <asset>
        <!-- solid dark background -->
        <texture type="skybox"
                builtin="gradient"
                rgb1="0 0 0"
                rgb2="0 0 0"
                width="512"
                height="512"/>


        <!-- subtle dark grid floor -->
        <texture type="2d" name="groundplane"
                 builtin="checker"
                 rgb1="0.08 0.08 0.09"
                 rgb2="0.04 0.04 0.045"
                 width="300" height="300"/>

        <material name="groundplane"
                  texture="groundplane"
                  texuniform="true"
                  texrepeat="6 6"
                  reflectance="0"/>
    </asset>

    <worldbody>
        <camera name="ortho_side"
            mode="fixed"
            orthographic="true"
            pos="0.05 -1 0.15"
            xyaxes="1 0 0  0 0 1"
            fovy="0.33"/>
        <body name="link1" pos="0 0 0.24">
            <joint name="joint1" />
            <geom fromto="0 0 0 0.06 0 0" size="0.008" rgba="0.8 0.6 0.5 1"/>
            <body name="link2" pos="0.06 0 0">
                <joint name="joint2"/>
                <geom fromto="0 0 0 0.06 0 0" size="0.008" rgba="0.8 0.6 0.5 1"/>
                <body name="link3" pos="0.06 0 0">
                    <joint name="joint3"/>
                    <geom fromto="0 0 0 0.06 0 0" size="0.008" rgba="0.8 0.6 0.5 1"/>
                    <body name="link4" pos="0.06 0 0">
                        <joint name="joint4"/>
                        <geom fromto="0 0 0 0.06 0 0" size="0.008" rgba="0.8 0.6 0.5 1"/>
                        <body name="attachment" pos="0.06 0.0 0.0">
                              <site name="ee" rgba="1 0 0 1" size="0.001" group="1"/>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <worldbody>
        <body name="target" pos="0.1 0.0 -0.15" quat="0 1 0 0" mocap="true">
        <site type="sphere" size="0.01" rgba="1 0.2 0.2 0.9" group="2"/>
        </body>
    </worldbody>

        <visual>

        <!-- remove haze completely -->
        <rgba haze="0 0 0 0"/>

        <!-- softer light on dark bg -->
        <headlight diffuse="0.9 0.9 0.9"
                ambient="0.15 0.15 0.15"
                specular="0 0 0"/>

        <global azimuth="140"
                elevation="-20"
                offwidth="3840"
                offheight="2160"/>

    </visual>

    <!-- Tendon-based antagonistic actuation -->
    <tendon>
        <!-- Tendon pair A -->
        <fixed name="tendon_a_flex">
            <joint joint="joint1" coef="1"/>
            <joint joint="joint2" coef="1"/>
        </fixed>
        <fixed name="tendon_a_ext">
            <joint joint="joint1" coef="-1"/>
            <joint joint="joint2" coef="-1"/>
        </fixed>

        <!-- Tendon pair B -->
        <fixed name="tendon_b_flex">
            <joint joint="joint3" coef="1"/>
            <joint joint="joint4" coef="1"/>
        </fixed>
        <fixed name="tendon_b_ext">
            <joint joint="joint3" coef="-1"/>
            <joint joint="joint4" coef="-1"/>
        </fixed>
    </tendon>


    <!-- Actuators for tendons -->
    <actuator>
        <motor tendon="tendon_a_flex" ctrlrange="0 1" gear="0.1"/>
        <motor tendon="tendon_a_ext" ctrlrange="0 1" gear="0.1"/>
        <motor tendon="tendon_b_flex" ctrlrange="0 1" gear="0.1"/>
        <motor tendon="tendon_b_ext" ctrlrange="0 1" gear="0.1"/>
    </actuator>
</mujoco>