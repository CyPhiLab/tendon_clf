<mujoco model="helix_control">
    <compiler angle="radian" meshdir="meshes/" autolimits="true" />
    <option integrator="implicitfast" timestep="0.005" gravity="0 0 0" cone="elliptic">
    </option>
    <include file="helix_body.xml" />
    <include file="helix_actuators.xml" />
    <include file="helix_sensors.xml" />
    <worldbody>
        <camera name="ortho_side"
        mode="fixed"
        pos="0.09 35.0 0.6"
        xyaxes="-1 0 0   0 0 1"
        fovy="1.5"/>
        <body name="target" pos="0.0 0 0.05" quat="0 1 0 0" mocap="true">
        <!-- <geom type="box" size=".05 .05 .05" contype="0" conaffinity="0" rgba=".6 .3 .3 .5"/> -->
        <site type="sphere" size="0.015" rgba="1 0.2 0.2 0.9" group="2"/>
        </body>
        <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    </worldbody>

    <visual>

        <!-- remove haze completely -->
        <rgba haze="0 0 0 0"/>

        <!-- softer light on dark bg -->
        <headlight diffuse="0.9 0.9 0.9"
                ambient="0.15 0.15 0.15"
                specular="0 0 0"/>

        <global azimuth="140"
                elevation="-20"
                offwidth="3840"
                offheight="2160"/>

    </visual>


    <asset>
        <texture type="skybox"
                builtin="gradient"
                rgb1="0 0 0"
                rgb2="0 0 0"
                width="512"
                height="512"/>

        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
            markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>

<worldbody>

</worldbody>
</mujoco>